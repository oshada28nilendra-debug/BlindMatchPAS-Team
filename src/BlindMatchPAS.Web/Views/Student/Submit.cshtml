@model BlindMatchPAS.Web.ViewModels.Student.ProjectSubmitViewModel
@{
    ViewData["Title"] = Model.Id > 0 ? "Edit Project" : "Submit Project";
    Layout = "_Layout";
    var isEdit = Model.Id > 0;
}

<div class="page-header">
    <h1><i class="bi bi-file-earmark-@(isEdit ? "text" : "plus")-fill me-2 text-gradient"></i>@ViewData["Title"]</h1>
    <p class="text-muted small mb-0">@(isEdit ? "Update your project proposal" : "Describe your research project proposal")</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="pas-card">
            <form asp-controller="Student" asp-action="@(isEdit ? "Edit" : "Submit")"
                  asp-route-id="@(isEdit ? Model.Id : null)" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors mb-3"></div>

                <div class="mb-4">
                    <label asp-for="Title" class="form-label">Project Title</label>
                    <input asp-for="Title" class="form-control" placeholder="A brief, descriptive title for your project" id="projectTitle" />
                    <span asp-validation-for="Title" class="field-validation-error"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ResearchAreaId" class="form-label">Research Area</label>
                    <select asp-for="ResearchAreaId" class="form-select"
                            asp-items="@(new SelectList(Model.ResearchAreas, "Id", "Name"))" id="projectResearchArea">
                        <option value="">— Select a research area —</option>
                    </select>
                    <span asp-validation-for="ResearchAreaId" class="field-validation-error"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="TechStack" class="form-label">Technology Stack</label>
                    <input asp-for="TechStack" class="form-control"
                           placeholder="e.g. Python, TensorFlow, React, PostgreSQL" id="projectTechStack" />
                    <span asp-validation-for="TechStack" class="field-validation-error"></span>
                    <div class="small text-muted mt-1">List the technologies, languages and frameworks you plan to use.</div>
                </div>

                <div class="mb-4">
                    <label asp-for="Abstract" class="form-label">Abstract</label>
                    <textarea asp-for="Abstract" class="form-control" rows="7"
                              placeholder="Describe your project in at least 50 characters: background, objectives, methodology and expected outcomes."
                              id="projectAbstract"></textarea>
                    <span asp-validation-for="Abstract" class="field-validation-error"></span>
                    <div class="small text-muted mt-1">
                        <span id="charCount">0</span> / 2000 characters
                    </div>
                </div>

                @if (!isEdit)
                {
                    <div class="p-3 rounded mb-4" style="background:rgba(139,92,246,0.08);border:1px solid rgba(139,92,246,0.25)">
                        <div class="small"><i class="bi bi-shield-lock me-2 text-primary"></i>
                            <strong>Blind Matching:</strong> Your name and student ID will remain hidden from supervisors until a match is confirmed.
                        </div>
                    </div>
                }

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary px-5" id="saveProjectBtn">
                        <i class="bi bi-@(isEdit ? "save" : "send") me-2"></i>@(isEdit ? "Save Changes" : "Submit Proposal")
                    </button>
                    <a asp-controller="Student" asp-action="Dashboard" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const abstractEl = document.getElementById('projectAbstract');
    const charCount = document.getElementById('charCount');
    if (abstractEl) {
        const update = () => { charCount.textContent = abstractEl.value.length; };
        abstractEl.addEventListener('input', update);
        update();
    }
</script>
}
