@model BlindMatchPAS.Web.Models.Match
@using BlindMatchPAS.Web.Models.Enums
@{
    ViewData["Title"] = "Match Details";
    Layout = "_Layout";
    var isRevealed = Model.Status == MatchStatus.Revealed;
}

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-3">
    <div>
        <h1 class="mb-1"><i class="bi bi-link-45deg me-2 text-gradient"></i>Match Details</h1>
        <p class="text-muted small mb-0">Match #@Model.Id</p>
    </div>
    <a asp-controller="Supervisor" asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <!-- Project Info (Anonymous until reveal) -->
        <div class="pas-card mb-4">
            <div class="d-flex align-items-center gap-2 mb-3">
                @{
                    var (mbClass, mlabel) = Model.Status switch {
                        MatchStatus.Interested => ("badge-interested", "Interested"),
                        MatchStatus.Confirmed  => ("badge-confirmed",  "Confirmed"),
                        MatchStatus.Revealed   => ("badge-revealed",   "Revealed"),
                        _                      => ("badge-pending",    "Unknown")
                    };
                }
                <span class="badge @mbClass px-3 py-1 rounded-pill">@mlabel</span>
                <span class="text-muted small"><i class="bi bi-tag me-1"></i>@Model.Project?.ResearchArea?.Name</span>
            </div>

            <h4 class="fw-700 mb-3">@Model.Project?.Title</h4>

            <h5 class="fw-600 text-muted small text-uppercase mb-1">Abstract</h5>
            <p class="mb-4" style="line-height:1.8">@Model.Project?.Abstract</p>

            <h5 class="fw-600 text-muted small text-uppercase mb-1">Technology Stack</h5>
            <div class="mb-0">
                @foreach (var tech in (Model.Project?.TechStack ?? "").Split(',', System.StringSplitOptions.TrimEntries))
                {
                    <span class="badge me-1 mb-1" style="background:rgba(139,92,246,0.15);color:#a78bfa;border:1px solid rgba(139,92,246,0.3);padding:5px 10px;border-radius:20px;font-weight:500">
                        @tech
                    </span>
                }
            </div>
        </div>

        <!-- Student Identity (only after reveal) -->
        @if (isRevealed)
        {
            <div class="pas-card" style="border-color:rgba(6,182,212,0.4);background:rgba(6,182,212,0.05)">
                <div class="reveal-badge mb-3"><i class="bi bi-person-fill-check"></i> Student Identity Revealed</div>
                <div class="fw-700 mb-1">@Model.Project?.Student?.FullName</div>
                <div class="small text-muted mb-1">@Model.Project?.Student?.Email</div>
                @if (Model.Project?.Student?.Department != null)
                {
                    <div class="small text-muted"><i class="bi bi-building me-1"></i>@Model.Project.Student.Department</div>
                }
                @if (Model.RevealedAt != null)
                {
                    <div class="small text-muted mt-2"><i class="bi bi-calendar-check me-1"></i>Revealed on @Model.RevealedAt.Value.ToString("dd MMM yyyy HH:mm")</div>
                }
            </div>
        }
        else
        {
            <div class="pas-card" style="background:rgba(139,92,246,0.04)">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon purple"><i class="bi bi-incognito"></i></div>
                    <div>
                        <div class="fw-600">Student Identity Hidden</div>
                        <div class="small text-muted">Confirm this match to reveal the student's details.</div>
                    </div>
                </div>
                <div class="mt-3">
                    <form asp-controller="Supervisor" asp-action="ConfirmMatch" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="matchId" value="@Model.Id" />
                        <button type="submit" class="btn btn-success" id="confirmMatchBtn"
                                onclick="return confirm('Confirm this match? The student\'s identity will be revealed to both of you.')">
                            <i class="bi bi-check2-circle me-2"></i>Confirm Match &amp; Reveal Identity
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="pas-card mb-4">
            <h5 class="fw-600 mb-3 small text-muted text-uppercase">Match Timeline</h5>
            <div class="d-flex flex-column gap-3">
                <div class="d-flex gap-3 align-items-start">
                    <div class="stat-icon purple" style="width:32px;height:32px;min-width:32px;font-size:.9rem;border-radius:8px">
                        <i class="bi bi-heart"></i>
                    </div>
                    <div>
                        <div class="small fw-600">Expressed Interest</div>
                        <div class="small text-muted">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                    </div>
                </div>
                @if (Model.ConfirmedAt != null)
                {
                    <div class="d-flex gap-3 align-items-start">
                        <div class="stat-icon green" style="width:32px;height:32px;min-width:32px;font-size:.9rem;border-radius:8px">
                            <i class="bi bi-check2"></i>
                        </div>
                        <div>
                            <div class="small fw-600">Match Confirmed</div>
                            <div class="small text-muted">@Model.ConfirmedAt.Value.ToString("dd MMM yyyy HH:mm")</div>
                        </div>
                    </div>
                }
                @if (Model.RevealedAt != null)
                {
                    <div class="d-flex gap-3 align-items-start">
                        <div class="stat-icon cyan" style="width:32px;height:32px;min-width:32px;font-size:.9rem;border-radius:8px">
                            <i class="bi bi-eye"></i>
                        </div>
                        <div>
                            <div class="small fw-600">Identities Revealed</div>
                            <div class="small text-muted">@Model.RevealedAt.Value.ToString("dd MMM yyyy HH:mm")</div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.SupervisorNotes))
        {
            <div class="pas-card">
                <h5 class="fw-600 mb-2 small text-muted text-uppercase">My Notes</h5>
                <p class="small mb-0">@Model.SupervisorNotes</p>
            </div>
        }
    </div>
</div>
