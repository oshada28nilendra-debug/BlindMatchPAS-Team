@model BlindMatchPAS.Web.ViewModels.Supervisor.SupervisorExpertiseViewModel
@{
    ViewData["Title"] = "Manage Expertise";
    Layout = "_Layout";
}

<div class="page-header">
    <h1><i class="bi bi-tags-fill me-2 text-gradient"></i>My Research Expertise</h1>
    <p class="text-muted small mb-0">Select the research areas you are qualified to supervise</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="pas-card">
            <form asp-controller="Supervisor" asp-action="ManageExpertise" method="post">
                @Html.AntiForgeryToken()

                <p class="text-muted small mb-4">
                    Projects in your selected research areas will appear in your browse list.
                </p>

                <div class="row g-3 mb-4">
                    @foreach (var area in Model.AllResearchAreas)
                    {
                        <div class="col-sm-6">
                            <div class="form-check p-3 rounded @(Model.SelectedResearchAreaIds.Contains(area.Id) ? "bg-primary bg-opacity-10 border border-primary border-opacity-25" : "")"
                                 style="border:1px solid var(--pas-border);border-radius:8px;">
                                <input class="form-check-input" type="checkbox"
                                       name="SelectedResearchAreaIds" value="@area.Id"
                                       id="expertise_@area.Id"
                                       @(Model.SelectedResearchAreaIds.Contains(area.Id) ? "checked" : "") />
                                <label class="form-check-label fw-500" for="expertise_@area.Id">
                                    @area.Name
                                </label>
                                @if (!string.IsNullOrEmpty(area.Description))
                                {
                                    <div class="small text-muted mt-1">@area.Description</div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary px-4" id="saveExpertiseBtn">
                        <i class="bi bi-save me-2"></i>Save Preferences
                    </button>
                    <a asp-controller="Supervisor" asp-action="Dashboard" class="btn btn-outline-secondary">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>
