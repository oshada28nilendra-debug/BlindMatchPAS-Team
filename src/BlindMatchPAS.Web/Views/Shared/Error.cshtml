@model BlindMatchPAS.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<div class="row justify-content-center py-5">
    <div class="col-md-6 text-center">
        <div style="font-size:5rem;margin-bottom:1rem;">⚠️</div>
        <h2 class="fw-700 mb-2">Something went wrong</h2>
        <p class="text-muted">An error occurred while processing your request.</p>

        @if (Model?.ShowRequestId == true)
        {
            <div class="pas-card mt-3 py-3 text-start">
                <div class="small text-muted mb-1">Request ID</div>
                <code class="small">@Model.RequestId</code>
            </div>
        }

        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-4">
            <i class="bi bi-house me-2"></i>Back to Home
        </a>
    </div>
</div>
