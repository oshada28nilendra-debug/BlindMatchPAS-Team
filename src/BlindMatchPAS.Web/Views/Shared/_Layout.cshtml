<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Blind-Match Project Approval System — anonymously match students with supervisors." />
    <title>@ViewData["Title"] — Blind-Match PAS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark pas-navbar">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <div class="brand-icon"><i class="bi bi-diagram-3-fill"></i></div>
                <span class="brand-text">Blind<span class="accent">Match</span></span>
                <span class="badge badge-pas ms-1">PAS</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Student" asp-action="Dashboard">
                                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Student" asp-action="Submit">
                                    <i class="bi bi-file-earmark-plus me-1"></i>Submit Project
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("Supervisor"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Supervisor" asp-action="Dashboard">
                                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Supervisor" asp-action="ManageExpertise">
                                    <i class="bi bi-tags me-1"></i>My Expertise
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("ModuleLeader") || User.IsInRole("SystemAdmin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear me-1"></i>Manage
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="AllMatches">
                                        <i class="bi bi-link-45deg me-2"></i>All Matches
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="ResearchAreas">
                                        <i class="bi bi-tags me-2"></i>Research Areas
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">
                                        <i class="bi bi-people me-2"></i>Users
                                    </a></li>
                                </ul>
                            </li>
                        }
                    }
                </ul>
                <ul class="navbar-nav align-items-center gap-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <span class="nav-link text-muted small">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-sm btn-outline-light me-2" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-sm btn-primary" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="pas-main">
        <div class="container py-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </main>

    <footer class="pas-footer">
        <div class="container text-center">
            <p class="mb-0 text-muted small">
                &copy; @DateTime.Now.Year <strong>Blind-Match PAS</strong> — Project Approval System
                <span class="mx-2">|</span>
                Built with ASP.NET Core 8 &amp; EF Core
            </p>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
