@model BlindMatchPAS.Web.ViewModels.Admin.ReassignProjectViewModel
@{
    ViewData["Title"] = "Reassign Match";
    Layout = "_Layout";
}

<div class="page-header">
    <h1><i class="bi bi-arrow-left-right me-2 text-gradient"></i>Reassign Match</h1>
    <p class="text-muted small mb-0">Assign a different supervisor to this project</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="pas-card">
            <div class="p-3 rounded mb-4" style="background:var(--pas-surface-2);border:1px solid var(--pas-border)">
                <div class="small text-muted mb-1">Project</div>
                <div class="fw-600">@Model.ProjectTitle</div>
                <div class="small text-muted">Match #@Model.MatchId</div>
            </div>

            <form asp-controller="Admin" asp-action="Reassign" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="MatchId" value="@Model.MatchId" />
                <input type="hidden" name="ProjectId" value="@Model.ProjectId" />
                <input type="hidden" name="ProjectTitle" value="@Model.ProjectTitle" />

                <div class="mb-4">
                    <label class="form-label">Select New Supervisor</label>
                    <select asp-for="NewSupervisorId" class="form-select" required id="newSupervisorSelect">
                        <option value="">— Select Supervisor —</option>
                        @foreach (var sup in Model.AvailableSupervisors)
                        {
                            <option value="@sup.Id">@sup.FullName (@sup.Email)</option>
                        }
                    </select>
                    <span asp-validation-for="NewSupervisorId" class="field-validation-error"></span>
                </div>

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary px-4" id="confirmReassignBtn"
                            onclick="return confirm('Reassign this match? The current supervisor will lose access.')">
                        <i class="bi bi-arrow-left-right me-2"></i>Confirm Reassignment
                    </button>
                    <a asp-controller="Admin" asp-action="AllMatches" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
